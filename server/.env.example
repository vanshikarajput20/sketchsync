# SketchSync — Server Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to version control

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=development

# ─── Redis ────────────────────────────────────────────────────────────────────
# Local:                redis://localhost:6379
# Railway Redis plugin: set automatically as REDIS_URL
# Upstash (free tier):  rediss://:password@host:port
REDIS_URL=redis://localhost:6379

# How long (seconds) to keep an idle room in Redis before expiry (default: 24 h)
REDIS_ROOM_TTL=86400

# ─── MongoDB ──────────────────────────────────────────────────────────────────
# Local:       mongodb://localhost:27017/sketchsync
# Atlas free:  mongodb+srv://user:pass@cluster.mongodb.net/sketchsync
MONGO_URI=mongodb://localhost:27017/sketchsync

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Space-separated list of allowed origins for Socket.IO + REST API
# Development: http://localhost:5173
# Production:  https://your-app.vercel.app
CORS_ORIGINS=http://localhost:5173

# ─── Auto-save ────────────────────────────────────────────────────────────────
# Persist board to MongoDB after this many new operations (default: 50)
AUTOSAVE_THRESHOLD=50
